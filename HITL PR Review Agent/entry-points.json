{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "/content/agent.json",
      "uniqueId": "56132de5-9047-4f58-8af1-8eee24547703",
      "type": "agent",
      "input": {
        "type": "object",
        "required": [
          "repositoryName",
          "owner",
          "pullRequestNumber",
          "title",
          "url"
        ],
        "properties": {
          "repositoryName": {
            "type": "string",
            "description": "Name of the GitHub repository"
          },
          "owner": {
            "type": "string",
            "description": "Owner of the GitHub repository"
          },
          "pullRequestNumber": {
            "type": "integer",
            "description": "Pull request number"
          },
          "title": {
            "type": "string",
            "description": "Pull request title"
          },
          "url": {
            "type": "string",
            "description": "Pull request URL"
          }
        },
        "title": "Inputs"
      },
      "output": {
        "type": "object",
        "required": [
          "decision",
          "reason",
          "confidence",
          "comment",
          "escalationRequired",
          "escalationPayload"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "description": "Decision status after creating the human review task",
            "enum": [
              "escalated",
              "error"
            ]
          },
          "reason": {
            "type": "string",
            "description": "Explanation of the escalation or missing input error"
          },
          "confidence": {
            "type": "string",
            "description": "Confidence level",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "comment": {
            "type": "string",
            "description": "Reviewer-facing comment"
          },
          "escalationRequired": {
            "type": "boolean",
            "description": "Whether human review is required"
          },
          "escalationPayload": {
            "type": "object",
            "description": "Payload sent to the Human Review App",
            "properties": {
              "repositoryName": {
                "type": "string"
              },
              "owner": {
                "type": "string"
              },
              "pullRequestNumber": {
                "type": "integer"
              },
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "escalationReason": {
                "type": "string"
              }
            }
          },
          "humanReviewOutcome": {
            "type": "object",
            "description": "Response returned by the Human Review App escalation tool"
          }
        }
      }
    }
  ]
}
