    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>Pull change details, requirement text, PR metadata, impacted apps, and baseline approvals.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>AI agent validates whether the change has enough information to plan testing.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>AI Agent identifies and produces risk score, impacted areas, test priority, and selects test set.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_4">
      <bpmn:text>Run selected Test Cloud/Test Manager validations</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_5">
      <bpmn:text>Classify failures as product defect, environment/test data issue, automation failure, or mixed</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_6">
      <bpmn:text>Produces Go, No-Go, or Needs Review using risk, failures, approvals, and evidence.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_SbnOXY">
      <bpmn:text>Triggered by ServiceNow change, GitHub PR, or release request.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_CuMPTw">
      <bpmn:text>Updates ServiceNow/GitHub/release record with decision, links, logs, screenshots, and audit package.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_mpHPOs">
      <bpmn:text>Create/update GitHub issue or defect record with failing test evidence.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_WDr1u9">
      <bpmn:text>PR merge confirmation will deploy the fix to Orchestrator packages</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_kEnchi">
      <bpmn:text>Update the Issue/Requirement Comments with the detailed Failure information</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_k3X290">
      <bpmn:text>Coding agent proposes fix/suggestions through Pull Request</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_IgBax0">
      <bpmn:text>Human reviews and approves, rejects, or requests changes</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_yrQwo0">
      <bpmn:text>Assign environment/data remediation to the right owner or system.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_oXErh2">
      <bpmn:text>Update GitHub/SNOW, or any other requirement with any missing information</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_FJhFZ0">
      <bpmn:text>Process ends only after the decision and evidence are written.</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
