{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "Main.xaml",
      "uniqueId": "9c268dd9-7624-4406-bd75-10d858f15947",
      "type": "Process",
      "input": {
        "type": "object",
        "properties": {
          "repositoryName": {
            "type": "string",
            "description": "Name of the GitHub repository"
          },
          "owner": {
            "type": "string",
            "description": "Owner of the GitHub repository"
          },
          "pullRequestNumber": {
            "type": "integer",
            "description": "Pull request number"
          },
          "title": {
            "type": "string",
            "description": "Pull request title"
          },
          "url": {
            "type": "string",
            "description": "Pull request URL"
          },
          "summary": {
            "type": "string",
            "description": "Pull request summary or description"
          },
          "comments": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Comments on the pull request"
          },
          "changedFiles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of changed files in the pull request"
          },
          "escalationReason": {
            "type": "string",
            "description": "Reason for escalating to human review"
          }
        },
        "required": [
          "repositoryName",
          "owner",
          "pullRequestNumber",
          "title",
          "url",
          "summary",
          "comments",
          "changedFiles",
          "escalationReason"
        ]
      },
      "output": {
        "type": "object",
        "properties": {
          "pullRequestNumber": {
            "type": "integer",
            "description": "Pull request number"
          },
          "decision": {
            "type": "string",
            "enum": ["approved", "rejected"],
            "description": "Human reviewer decision"
          },
          "comment": {
            "type": "string",
            "description": "Reviewer comment"
          },
          "reviewer": {
            "type": "string",
            "description": "Name of the reviewer"
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp of the review"
          },
          "targetConnector": {
            "type": "string",
            "description": "Target connector name"
          },
          "finalDecision": {
            "type": "string",
            "description": "Final decision to surface after HITL review"
          },
          "finalComment": {
            "type": "string",
            "description": "Final comment to surface after HITL review"
          }
        },
        "required": [
          "pullRequestNumber",
          "decision",
          "comment",
          "reviewer",
          "updatedAt",
          "targetConnector",
          "finalDecision",
          "finalComment"
        ]
      }
    }
  ]
}